SMTP_PORT=2525
API_PORT=8025
DATA_DIR=./data
QUARANTINE_TTL_HOURS=168
SWEEPER_INTERVAL_SEC=60
LOG_LEVEL=info

# Outbound delivery
SEND_MODE=loopback                  # loopback | relay
DKIM_SELECTOR=zs1

# Relay (only used when SEND_MODE=relay)
RELAY_HOST=
RELAY_PORT=587
RELAY_USER=
RELAY_PASS=
RELAY_SECURE=false                  # true for implicit-TLS (port 465)

# Outlook inbound pipeline (slice 2). Azure app registration (authority: common).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
