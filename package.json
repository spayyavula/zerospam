{
  "name": "zerospam-email",
  "version": "0.1.0",
  "private": true,
  "description": "Whitelist-first SMTP server + webmail. Default-deny inbox; everything else expires from quarantine.",
  "workspaces": [
    "server",
    "web",
    "apps/mobile",
    "packages/shared-api"
  ],
  "scripts": {
    "dev": "concurrently -n server,web,mobile -c blue,green,magenta \"npm:dev:server\" \"npm:dev:web\" \"npm:dev:mobile\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "dev:mobile": "npm run start --workspace=@zerospam/mobile",
    "build": "npm run build:shared-api && npm run build --workspace=web && npm run build --workspace=server",
    "build:mobile": "npm run build --workspace=@zerospam/mobile",
    "build:shared-api": "npm run build --workspace=@zerospam/shared-api",
    "typecheck:mobile": "npm run typecheck --workspace=@zerospam/mobile",
    "lint:mobile": "npm run lint --workspace=@zerospam/mobile",
    "start": "npm run start --workspace=server",
    "seed": "tsx server/src/seed.ts",
    "seed:owner": "tsx server/src/seed-owner.ts",
    "seed:demo": "tsx server/src/seed-demo.ts",
    "inject": "tsx server/src/inject.ts"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "nodemailer": "^8.0.7",
    "undici": "^7.24.8",
    "fast-xml-parser": "^5.7.2"
  }
}
